# n8n webhook URL for lead submission (optional, secondary integration)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/roostertail-lead

# GoHighLevel API (required for lead submission)
GHL_API_KEY=your-ghl-api-key
GHL_LOCATION_ID=your-ghl-location-id

# Meta Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=

# GA4 Measurement ID
NEXT_PUBLIC_GA4_ID=
